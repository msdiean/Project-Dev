pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/msdiean/Project-Dev.git'
            }
        }

        stage('Node Version') {
            steps {
                sh 'node -v'
                sh 'npm -v'
            }
        }

        stage('NPM Install') {
            steps {
                dir('app/frontend') {
                    sh '''
                    export NODE_OPTIONS=--openssl-legacy-provider
                    npm install
                    '''
                }
            }
        }

        stage('Build') {
            steps {
                dir('app/frontend') {
                    sh '''
                    export NODE_OPTIONS=--openssl-legacy-provider
                    npm run build
                    '''
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline Completed'
        }
    }
}
